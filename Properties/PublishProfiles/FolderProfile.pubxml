<?xml version="1.0" encoding="utf-8"?>
<!--
  FolderProfile.pubxml - Creates the self-contained portable build.

  Usage: Right-click project → Publish → FolderProfile, then zip portable\.

  Output:
    - portable\ : Self-contained, single-file win-x64 portable build (no .NET runtime needed on the
      target PC). Its own dedicated dir (not the shared build\, which installer tooling clears) and
      wiped clean on each publish, so the zip always contains exactly the published files.
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishDir>portable\</PublishDir>
    <!-- Clear the output dir before publishing so stale files never end up in the portable zip. -->
    <DeleteExistingFiles>true</DeleteExistingFiles>
    <PublishProtocol>FileSystem</PublishProtocol>
    <_TargetId>Folder</_TargetId>
    <TargetFramework>net8.0-windows</TargetFramework>
    <!-- Self-contained win-x64, matching the installer's tested publish. Framework-dependent Any-CPU
         portable builds forced users to have the .NET Desktop Runtime and resolved the native
         WebView2Loader.dll via RID-less probing — variables behind the portable-only WebView2
         failures. Self-contained bundles .NET and flattens the loader next to the exe. -->
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <!-- Single-file: bundle the ~250 self-contained runtime assemblies INTO the exe so the portable
         folder is clean (exe + native tools + Assets\), instead of 264 loose files. Overrides the
         csproj's PublishSingleFile=false, which the installed (multi-file) build keeps.
         IncludeNativeLibrariesForSelfExtract=false keeps native libs LOOSE next to the exe — no
         temp extraction at launch, and WebView2Loader.dll stays beside the exe (preserves the
         portable WebView2 reliability fix). The bundled managed assemblies are memory-mapped, not
         extracted, on .NET 8. -->
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>false</IncludeNativeLibrariesForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <!-- Drop .NET's built-in satellite resource folders (cs/de/es/fr/…) — the app localizes via its
         own JSON catalog, not framework satellites, so these ~13 folders are dead weight. -->
    <SatelliteResourceLanguages>en</SatelliteResourceLanguages>
  </PropertyGroup>
</Project>